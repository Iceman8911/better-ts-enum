{
	"name": "@iceman8911/better-enum",
	"version": "0.1.0",
	"description": "Yet another typescript enum replacement. It'll be good trust",
	"homepage": "https://github.com/iceman8911/better-enum#readme",
	"bugs": {
		"url": "https://github.com/iceman8911/better-enum/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/iceman8911/better-enum.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		"./basic-enum": {
			"import": {
				"types": "./dist/basic-enum.d.ts",
				"default": "./dist/basic-enum.js",
				"require": "./dist/basic-enum.cjs"
			}
		},
		"./min/basic-enum": {
			"import": {
				"types": "./dist/min/basic-enum.d.ts",
				"default": "./dist/min/basic-enum.js",
				"require": "./dist/min/basic-enum.cjs"
			}
		},
		"./arithmetic": {
			"import": {
				"types": "./dist/arithmetic.d.ts",
				"default": "./dist/arithmetic.js",
				"require": "./dist/arithmetic.cjs"
			}
		},
		"./min/arithmetic": {
			"import": {
				"types": "./dist/min/arithmetic.d.ts",
				"default": "./dist/min/arithmetic.js",
				"require": "./dist/min/arithmetic.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"format": "oxfmt",
		"lint": "oxlint",
		"prepare": "bun simple-git-hooks",
		"release": "bumpp --commit --push --tag",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"test:watch": "bun test --watch",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"bumpp": "^10.4.1",
		"bunup": "^0.16.31",
		"oxfmt": "^0.40.0",
		"oxlint": "^1.55.0",
		"simple-git-hooks": "^2.13.1",
		"ts-arithmetic": "^0.1.1",
		"type-fest": "^5.4.4",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"typescript": ">=4.5.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"simple-git-hooks": {
		"pre-commit": "bun run lint && bun run type-check && bun run format"
	}
}
